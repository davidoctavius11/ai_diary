# DeepSeek — diary translation + chatbot
# Get a key at: https://platform.deepseek.com
OPENAI_API_KEY=your-deepseek-api-key
OPENAI_BASE_URL=https://api.deepseek.com/v1

# Zhipu AI — photo analysis (vision)
# Get a free key at: https://open.bigmodel.cn
ZHIPU_API_KEY=your-zhipu-api-key

# Anthropic — optional, not currently used (credits ran out, switched to above)
ANTHROPIC_API_KEY=

# Child info
CHILD_NAME=白小白
CHILD_NAME_EN=Brian
CHILD_BIRTH_YEAR=2019

# Mac Photos — which albums/faces to sync
# KIDS_PEOPLE: comma-separated names as they appear in Photos > People
# KIDS_ALBUMS: comma-separated shared album names
KIDS_PEOPLE=白小白
KIDS_ALBUMS=This is us

# Cost controls
DAILY_PHOTO_LIMIT=50       # max photos analyzed per day (~$0.15)
DAILY_BUDGET_USD=10.00     # hard daily spend cap across all operations

# Family members: iPhoto face name → role description (semicolon-separated)
# Used to enrich photo descriptions with real names instead of "the child"
FAMILY_MEMBERS=白小白:大儿子Brian;白又白:小儿子;爸爸:爸爸;妈妈:妈妈

# Timezone
TZ=Asia/Shanghai
